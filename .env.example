# Data source for the swappable repository layer: "mock" (default) or "supabase"
NEXT_PUBLIC_DATA_SOURCE=mock

# Supabase (only required when NEXT_PUBLIC_DATA_SOURCE=supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for SEO metadata / sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# College Scorecard enrichment (optional) — free key from https://api.data.gov/signup/
SCORECARD_API_KEY=

# Contact email sent to public APIs (OpenAlex/ROR politeness pool)
DATA_CONTACT_EMAIL=hamidleo1984@gmail.com
