# ── Data source ──────────────────────────────────────────────────────────────
# "mock" (default, in-memory JSON) or "supabase" (real database).
NEXT_PUBLIC_DATA_SOURCE=mock

# Public site URL (SEO metadata, sitemap, Stripe redirect URLs, emails).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (database + auth) ───────────────────────────────────────────────
# Required when NEXT_PUBLIC_DATA_SOURCE=supabase and for auth / admin / billing.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Used by the seed script, Stripe webhook,
# admin panel and cron. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin access ─────────────────────────────────────────────────────────────
# Comma-separated emails that can see /admin. (Also seeded in migration 0002.)
ADMIN_EMAILS=emadcomircom@gmail.com

# ── Stripe (subscriptions) ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# The recurring Price ID for UNIREAL Pro (price_...).
STRIPE_PRICE_ID=

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=
# Must be a verified sender on your domain, e.g. "UNIREAL <noreply@yourdomain>".
EMAIL_FROM=

# Shared secret protecting the cron endpoint (Vercel sends it as a Bearer token).
CRON_SECRET=

# ── Data enrichment scripts (optional) ───────────────────────────────────────
SCORECARD_API_KEY=
DATA_CONTACT_EMAIL=hamidleo1984@gmail.com
